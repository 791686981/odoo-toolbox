TOOLBOX_SECRET_KEY=replace-this-secret
TOOLBOX_DEBUG=false
TOOLBOX_OPENAI_BASE_URL=https://api.openai.com/v1
TOOLBOX_OPENAI_API_KEY=
TOOLBOX_OPENAI_TRANSLATION_MODEL=gpt-4.1-mini
TOOLBOX_OPENAI_REVIEW_MODEL=

TOOLBOX_DATABASE_URL=postgresql+psycopg://toolbox:toolbox@postgres:5432/toolbox
TOOLBOX_REDIS_URL=redis://redis:6379/0
TOOLBOX_UPLOAD_DIR=/app/storage/uploads
TOOLBOX_OUTPUT_DIR=/app/storage/outputs
TOOLBOX_EAGER_TASKS=false

TOOLBOX_ADMIN_USERNAME=admin
TOOLBOX_ADMIN_PASSWORD=
TOOLBOX_DEFAULT_SOURCE_LANGUAGE=en_US
TOOLBOX_DEFAULT_TARGET_LANGUAGE=zh_CN
TOOLBOX_DEFAULT_CHUNK_SIZE=20
TOOLBOX_DEFAULT_CONCURRENCY=2
TOOLBOX_DEFAULT_OVERWRITE_EXISTING=false

# MCP Server (留空则不启用)
TOOLBOX_MCP_API_KEY=
